rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidProgress(data) {
      return data.lessonId is number &&
             data.completed is bool &&
             data.score is number &&
             data.score >= 0 && data.score <= 100 &&
             data.lastStudied is string &&
             data.keys().hasAll(['lessonId', 'completed', 'score', 'lastStudied']) &&
             data.keys().size() == 4;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      
      match /progress/{lessonId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(lessonId) && isValidProgress(request.resource.data);
        allow update: if isOwner(userId) && isValidProgress(request.resource.data) &&
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completed', 'score', 'lastStudied']));
      }
    }
  }
}
